#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../lib/i18n-js/version"

def write_file(path, contents)
  File.open(File.expand_path(path), "w") do |io|
    io << contents
  end
end

changelog_path = "./CHANGELOG.md"
version_path = "./lib/i18n-js/version.rb"

version = nil
segments = I18nJS::VERSION.split(".")
major, minor, patch = *segments.take(3).map(&:to_i)
pre = segments[3].to_s
pre_version = pre.gsub(/(alpha|rc)/m, "").to_i
pre_track = pre.gsub(/\d*/, "")
date = Time.now.strftime("%b %d, %Y")
dry_run = false
selected = []

OptionParser.new do |opts|
  opts.on("--major") do
    selected << "--major"
    version = "#{major + 1}.0.0"
  end

  opts.on("--minor") do
    selected << "--minor"
    version = "#{major}.#{minor + 1}.0"
  end

  opts.on("--patch") do
    selected << "--patch"
    version = "#{major}.#{minor}.#{patch + 1}"
  end

  opts.on("--alpha") do
    if pre_track == "rc"
      puts "ERROR: You cannot release an alpha version after an rc " \
           "version (v#{I18nJS::VERSION}). Please use --rc or release a " \
           "stable version without it."
      exit 1
    end

    pre_track = "alpha"
  end

  opts.on("--rc") do
    pre_track = "rc"
  end

  opts.on("--dry-run") do
    dry_run = true
  end
end.parse!

if selected.size > 1
  puts "ERROR: You can only use one of: #{selected.join(', ')}"
  exit 1
end

version = "#{version}.#{pre_track}#{pre_version + 1}" unless pre_track.empty?

unless version
  puts "ERROR: You need to use either one of: --major, --minor, --patch"
  exit 1
end

puts "=> Current version: #{I18nJS::VERSION}"
puts "=> Next version: #{version}"

system "npm", "install", exception: true
system "npm", "run", "compile", exception: true
system "rake", exception: true

write_file changelog_path,
           File.read(changelog_path)
               .gsub("Unreleased", "v#{version} - #{date}")

puts "=> Updated #{changelog_path}"

write_file version_path,
           File.read(version_path)
               .gsub(/VERSION = ".*?"/, %[VERSION = "#{version}"])

puts "=> Updated #{version_path}"

unless dry_run
  system "git", "add", changelog_path, version_path, exception: true
  system "git", "commit", "-m", "Bump up version (v#{version})", exception: true
  system "rake", "release", exception: true
end

if dry_run
  system "rake", "build", exception: true
  system "git", "checkout", changelog_path, version_path, exception: true
end
